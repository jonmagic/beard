#!/usr/bin/env bash
set -euo pipefail

PROJECT_DIR="${BEARD_PROJECT_DIR:-/Users/jonmagic/code/jonmagic/beard}"
LABEL="com.jonmagic.beard-battery-relay"
PLIST_SOURCE="$PROJECT_DIR/launchd/$LABEL.plist"
PLIST_DEST="$HOME/Library/LaunchAgents/$LABEL.plist"
DOMAIN="gui/$(/usr/bin/id -u)"
RUN_NOW="1"

if [[ "${1:-}" == "--no-run-now" ]]; then
  RUN_NOW="0"
fi

cd "$PROJECT_DIR"
/usr/bin/swift build -c release

/bin/mkdir -p "$HOME/Library/LaunchAgents"
/bin/chmod +x "$PROJECT_DIR/scripts/beard-battery-relay"
/usr/bin/plutil -lint "$PLIST_SOURCE"
/bin/cp "$PLIST_SOURCE" "$PLIST_DEST"
/usr/bin/plutil -lint "$PLIST_DEST"

/bin/launchctl bootout "$DOMAIN" "$PLIST_DEST" >/dev/null 2>&1 || true
/bin/launchctl bootstrap "$DOMAIN" "$PLIST_DEST"
/bin/launchctl enable "$DOMAIN/$LABEL"

if [[ "$RUN_NOW" == "1" ]]; then
  /bin/launchctl kickstart -k "$DOMAIN/$LABEL"
fi

/bin/launchctl print "$DOMAIN/$LABEL" | /usr/bin/sed -n '1,80p'
